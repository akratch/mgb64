// MGB64 Windows executable icon. The .ico is a single-entry, PNG-compressed
// (Vista+) icon wrapping branding/appicon-source.png byte-for-byte --
// see scripts/wrap_png_as_ico.sh.
IDI_ICON1 ICON "../branding/appicon-windows.ico"

// ---------------------------------------------------------------------------
// VERSIONINFO — what Explorer's Properties>Details dialog and Windows game
// launchers read for the product name + version. There is no compiled-in
// version anywhere else in the tree (the release label flows only as a string
// into the packaging scripts), so this is the single embedded source of truth
// for the shipped binary's identity.
//
// The numeric FILEVERSION/PRODUCTVERSION and the human FileVersion/
// ProductVersion strings are overridable at build time via -DMGB64_VER_CSV and
// -DMGB64_VER_STR, which CMake derives from the MGB64_VERSION cache variable
// (default 0.0.0 -> "0.0.0-dev"). The #ifndef defaults keep a bare
// `windres mgb64.rc` invocation (no -D) working standalone.
#include <windows.h>

#ifndef MGB64_VER_CSV
#define MGB64_VER_CSV 0, 0, 0, 0
#endif
#ifndef MGB64_VER_STR
#define MGB64_VER_STR 0.0.0-dev
#endif
// Stringize the token form so callers pass -DMGB64_VER_STR=0.3.3 (no embedded
// quotes to escape across CMake -> windres).
#define MGB64_STR2(x) #x
#define MGB64_STR(x) MGB64_STR2(x)

VS_VERSION_INFO VERSIONINFO
 FILEVERSION MGB64_VER_CSV
 PRODUCTVERSION MGB64_VER_CSV
 FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
 FILEFLAGS 0x0L
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"  // U.S. English, Unicode (1200) codepage
        BEGIN
            VALUE "CompanyName",      "MGB64 project"
            VALUE "FileDescription",  "MGB64"
            VALUE "FileVersion",      MGB64_STR(MGB64_VER_STR)
            VALUE "InternalName",     "ge007"
            VALUE "OriginalFilename", "ge007.exe"
            VALUE "ProductName",      "MGB64"
            VALUE "ProductVersion",   MGB64_STR(MGB64_VER_STR)
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200  // 0x409 = U.S. English, 1200 = Unicode
    END
END
