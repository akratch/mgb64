# Normalize text files across platforms.
* text=auto eol=lf

# Common ROM/media/build artifacts should stay binary if they ever appear
# locally; the release guards still forbid committing them.
*.z64 binary
*.n64 binary
*.v64 binary
*.rom binary
*.bin binary
*.bmp binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.raw binary
*.wav binary
*.mp3 binary
*.ogg binary
*.flac binary
*.dmg binary
*.zip binary
*.7z binary
*.tar binary
*.tgz binary
*.gz binary

# Keep GitHub language statistics focused on MGB64-owned code. These paths are
# inventoried in THIRD_PARTY.md and retained for build/tooling compatibility.
lib/glad/** linguist-vendored
tools/armips.cpp linguist-vendored
tools/asm-processor/** linguist-vendored
tools/extractor/puff.c linguist-vendored
tools/extractor/puff.h linguist-vendored
tools/gzipsrc/** linguist-vendored
tools/smaa/AreaTex.py linguist-vendored
tools/smaa/SearchTex.py linguist-vendored
tools/ido5.3_recomp/** linguist-vendored
tools/mktex/src/libpdtex/** linguist-vendored

# --- Internal working documentation: the public/internal boundary ------------
# The documentation boundary is now STRUCTURAL, not suffix-guessed:
#
#   docs/*.md        -> PUBLIC curated reference (see docs/README.md).
#   docs/design/**   -> INTERNAL design notes, roadmaps, and forward-looking
#                       plans. Kept in THIS development repository for maintainers
#                       and contributors with access, but NEVER shipped in the
#                       public source archive (`git archive`, honored
#                       automatically) or the fresh public launch repository
#                       (scripts/create_public_launch_repo.sh filters the tree by
#                       these entries).
#
# This block is the single source of truth for what documentation is public vs
# internal. For any new internal doc, put it under docs/design/ (do not add
# ad-hoc top-level exclusions — top-level docs/ is the public reference surface).
docs/design/** export-ignore
#
# LEGACY paths, retained on purpose. Internal docs previously lived at these
# paths (before consolidation under docs/design/). They match nothing in the
# current tree, but scripts/ci/check_public_history_text.sh derives its
# git-HISTORY scan exclusions from this list — so these entries keep that guard
# from scanning (and flagging) historical internal content that is now gone from
# HEAD. Do not remove them without also updating that guard.
docs/superpowers/** export-ignore
docs/remaster-aaa/** export-ignore
docs/*_PLAN.md export-ignore
docs/*_ROADMAP.md export-ignore
docs/*_REVIEW.md export-ignore
docs/PRE_SHIP_REVIEW_*.md export-ignore
docs/*_AUDIT_*.md export-ignore
docs/*_SURVEY.md export-ignore
docs/*_WIP.md export-ignore
docs/*_STATUS.md export-ignore
docs/*_GLIDEPATH.md export-ignore
docs/*_MAP.md export-ignore
docs/*_GUIDE.md export-ignore
docs/*_THEORY.md export-ignore
