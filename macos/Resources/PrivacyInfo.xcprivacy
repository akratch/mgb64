<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  PrivacyInfo.xcprivacy — Required since Spring 2024 for apps using
  certain Apple APIs. Declares which "required reason" APIs the app uses
  and why. Without this, App Store Connect rejects the binary, and
  Gatekeeper may warn users on direct distribution.
-->
<plist version="1.0">
<dict>
    <!-- No tracking domains or tracking data collection -->
    <key>NSPrivacyTracking</key>
    <false/>
    <key>NSPrivacyTrackingDomains</key>
    <array/>
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>

    <!-- Required Reason APIs we use -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <!-- UserDefaults: used for app preferences, onboarding state, ROM path -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- CA92.1: Access info from within the app itself -->
                <string>CA92.1</string>
            </array>
        </dict>
        <!-- File timestamp: used for screenshot naming -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- C617.1: Access within the app's container -->
                <string>C617.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
