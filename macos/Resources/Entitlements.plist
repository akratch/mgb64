<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Allow loading SDL2.framework (or other unsigned dylibs) under Hardened Runtime -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>

	<!-- JIT-compiled shader code may require writable+executable memory -->
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>

	<!-- GCController framework access for N64 gamepad mapping -->
	<key>com.apple.security.device.game-controllers</key>
	<true/>

	<!-- Microphone not needed — explicitly deny -->
	<key>com.apple.security.device.audio-input</key>
	<false/>
</dict>
</plist>
