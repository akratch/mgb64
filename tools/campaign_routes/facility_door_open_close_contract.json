{
  "schema": "mgb64.campaign_route.v1",
  "name": "facility_door_open_close_contract",
  "level": 34,
  "frames": 150,
  "route_class": "scripted_contract",
  "description": "Facility door interaction contract. Bond is deterministically placed at door object 158, then real B input opens and reverses the door while interact, door, and camera-clearance traces prove the transition. [Recalibrated 2026-07-19 for FID-0132: with the retail-correct door collision footprint the camera-clearance ray grazes the closing door 4x (was 20+ against the degenerate half-hull); the assertion still proves the clearance path fires. Attribution via GE007_NO_HULL_CORNER_FIX=1 A/B. See docs/fidelity/ledger/FID-0132.json.]",
  "env": {
    "GE007_DEBUG": 1,
    "GE007_ASSERT_ON_FAIL": 0,
    "GE007_DISABLE_LEVEL_INTRO": 1,
    "GE007_DOOR_TRACE": 1,
    "GE007_DOOR_TRACE_OBJ": 158,
    "GE007_DOOR_TRACE_BUDGET": 260,
    "GE007_INTERACT_TRACE": 1,
    "GE007_INTERACT_TRACE_BUDGET": 120,
    "GE007_RENDER_CAMERA_EXTRA_CLEARANCE": 6,
    "GE007_TRACE_CAMERA_CLEARANCE": 1,
    "GE007_TRACE_CAMERA_CLEARANCE_BUDGET": 260
  },
  "scripted_events": {
    "warps": [
      {"name": "pre_open_door_position", "frame": 40, "pad": 10077, "right_offset": 60, "forward_offset": -80, "y_offset": 0},
      {"name": "post_open_reverse_position", "frame": 72, "pad": 10077, "right_offset": 0, "forward_offset": 80, "y_offset": 0}
    ],
    "face_coord": [
      {"name": "face_door_open", "frame": 45, "x": 616.67, "y": -260.0, "z": 411.94},
      {"name": "face_door_reverse", "frame": 74, "x": 616.67, "y": -260.0, "z": 411.94}
    ]
  },
  "input_segments": [
    {"name": "door_open_press", "start": 55, "duration": 4, "inputs": ["b"]},
    {"name": "door_reverse_press", "start": 68, "duration": 4, "inputs": ["b"]}
  ],
  "assertions": {
    "expect_frame_exit": true,
    "min_records": 145,
    "no_render_failures": true,
    "no_front_failure": true,
    "log_count_assertions": [
      {
        "name": "two_real_door_allows",
        "pattern": "^\\[INTERACT_TRACE\\] door allow obj=158\\b",
        "min_count": 2
      },
      {
        "name": "door_open_state_transition",
        "pattern": "^\\[DOOR_TRACE\\] frame=\\d+ obj=158 state obj=158 0->1\\b",
        "min_count": 1
      },
      {
        "name": "door_open_displacement",
        "pattern": "^\\[DOOR_TRACE\\] frame=\\d+ obj=158 displace state=1\\b",
        "min_count": 8
      },
      {
        "name": "door_reverse_to_closing",
        "pattern": "^\\[DOOR_TRACE\\] frame=\\d+ obj=158 state obj=158 1->2\\b",
        "min_count": 1
      },
      {
        "name": "door_closing_displacement",
        "pattern": "^\\[DOOR_TRACE\\] frame=\\d+ obj=158 displace state=2\\b",
        "min_count": 20
      },
      {
        "name": "moving_closing_door_clearance_hits",
        "pattern": "^\\[CAM-CLEARANCE\\].*\\bhit_prop_type=2\\b.*\\bhit_obj=158\\b.*\\bhit_door_state=2\\b.*\\bhit_door_open=(?!0\\.000)0\\.\\d+",
        "min_count": 3
      }
    ],
    "setup_target_milestones": [
      {
        "name": "first_door_setup_target",
        "frame_at_or_after": 45,
        "target": {"kind": "object", "type_name": "door", "obj": 158, "pad": 77},
        "max_horizontal_distance": 130.0,
        "max_abs_y_delta": 140.0
      },
      {
        "name": "post_reverse_door_setup_target",
        "frame_at_or_after": 74,
        "target": {"kind": "object", "type_name": "door", "obj": 158, "pad": 77},
        "max_horizontal_distance": 90.0,
        "max_abs_y_delta": 140.0
      }
    ],
    "state_milestones": [
      {
        "name": "spawn_survival",
        "frame_at_or_after": 1,
        "checks": [
          {"path": "combat.health.actual_h", "op": ">=", "value": 1.0},
          {"path": "front.bond_kia", "op": "==", "value": 0},
          {"path": "front.mission_failed", "op": "==", "value": 0}
        ]
      },
      {
        "name": "post_door_sequence_stable",
        "frame_at_or_after": 140,
        "checks": [
          {"path": "combat.health.actual_h", "op": ">=", "value": 1.0},
          {"path": "front.active_stage", "op": "==", "value": 34},
          {"path": "front.bond_kia", "op": "==", "value": 0},
          {"path": "front.mission_failed", "op": "==", "value": 0}
        ]
      }
    ]
  }
}
