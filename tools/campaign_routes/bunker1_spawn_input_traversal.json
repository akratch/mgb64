  "assertions": {
    "expect_frame_exit": true,
    "min_records": 295,
    "no_render_failures": true,
    "no_front_failure": true,
    "require_input_automation": true,
    "no_direct_state_automation": true,
    "min_moving_records": 150,
    "min_horizontal_delta": 210.0,
    "setup_target_milestones": [
      {
        "name": "corridor_push_near_setup_pad_87",
        "frame_at_or_after": 140,
        "target": {"kind": "pad", "pad": 87},
        "max_horizontal_distance": 170.0
      }
    ],
    "position_milestones": [
      {
        "name": "corridor_contact",
        "frame_at_or_after": 140,
        "min_horizontal_delta": 210.0,
        "min_abs_x_delta": 25.0,
        "min_abs_z_delta": 210.0
      },
      {
        "name": "sustained_collision_push",
        "frame_at_or_after": 220,
        "min_horizontal_delta": 210.0,
        "min_abs_x_delta": 25.0,
        "min_abs_z_delta": 210.0
      },
      {
        "name": "post_input_coast",
        "frame_at_or_after": 299,
        "min_horizontal_delta": 210.0,
        "min_abs_x_delta": 25.0,
        "min_abs_z_delta": 210.0
      }
    ]
  }
}
