{
  "schema": "mgb64.campaign_route.v1",
  "name": "bunker1_spawn_input_traversal",
  "level": 9,
  "frames": 300,
  "route_class": "input_traversal",
  "description": "Bunker 1 spawn traversal through the real controller path. The route intentionally asserts the collision-limited forward-right corridor movement seen from spawn instead of overstating objective progress.",
  "env": {
    "GE007_TRACE_FLOW_ONLY": 1
  },
  "input_segments": [
    {"name": "corridor_diagonal_push", "start": 80, "duration": 160, "inputs": ["forward", "right"]}
