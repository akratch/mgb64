{
  "schema": "mgb64.campaign_route.v1",
  "name": "control_spawn_input_traversal",
  "description": "Control native input traversal from the stock spawn using forward movement. This is a spawn movement and collision guard, not a console-defense route.",
  "route_class": "input_traversal",
  "level": 23,
  "frames": 300,
  "env": {
    "GE007_TRACE_FLOW_ONLY": "1"
  },
  "input_segments": [
    {"name": "console_floor_push", "start": 80, "duration": 160, "inputs": ["forward"]}
