    "setup_target_milestones": [
      {
        "name": "console_floor_near_setup_pad_203",
        "frame_at_or_after": 140,
        "target": {"kind": "pad", "pad": 203},
        "max_horizontal_distance": 130.0
      }
    ],
    "position_milestones": [
      {
        "name": "console_room_entry_push",
        "frame_at_or_after": 140,
        "min_horizontal_delta": 190.0,
        "min_abs_x_delta": 120.0,
        "min_abs_z_delta": 140.0
      },
      {
        "name": "sustained_floor_push",
        "frame_at_or_after": 220,
        "min_horizontal_delta": 210.0,
        "min_abs_x_delta": 150.0,
        "min_abs_z_delta": 140.0
      },
      {
        "name": "post_input_coast",
        "frame_at_or_after": 299,
        "min_horizontal_delta": 210.0,
        "min_abs_x_delta": 150.0,
        "min_abs_z_delta": 140.0
      }
    ]
  }
