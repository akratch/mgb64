{
  "schema": "mgb64.campaign_route.v1",
  "name": "caverns_spawn_door_traversal_contract",
  "description": "Caverns stock-spawn controller route that opens the first ramp door, backs off to let it clear, and reaches the next-room pad cluster. This proves real input-driven door interaction and deeper traversal without warp, force, or stage-state automation. [Recalibrated 2026-07-19 for FID-0132: the collision-hull corner fix restores retail door/object footprints; Bond now stops at the closed ramp door's true collision face (hdelta ~119.9) where the pre-fix degenerate half-hull let him clip ~24 units deeper. Thresholds re-derived from the corrected deterministic run with margin; attribution proven via GE007_NO_HULL_CORNER_FIX=1 A/B. See docs/fidelity/ledger/FID-0132.json.]",
  "route_class": "input_interaction",
  "level": 39,
  "frames": 820,
  "env": {
    "GE007_TRACE_FLOW_ONLY": "1",
    "GE007_DOOR_TRACE": "1",
    "GE007_DOOR_TRACE_OBJ": "144",
    "GE007_DOOR_TRACE_BUDGET": "1000",
    "GE007_DOOR_TRACE_FRAME_MAX": "820",
    "GE007_INTERACT_TRACE": "1",
    "GE007_INTERACT_TRACE_BUDGET": "260"
  },
  "input_segments": [
    {"name": "ramp_door_approach", "start": 80, "duration": 100, "inputs": ["forward"]},
    {"name": "ramp_door_open_press", "start": 160, "duration": 8, "inputs": ["b"]},
    {"name": "door_clearance_backoff", "start": 170, "duration": 90, "inputs": ["back"]},
    {"name": "post_door_forward_push", "start": 300, "duration": 420, "inputs": ["forward"]}
  ],
  "assertions": {
    "expect_frame_exit": true,
    "min_records": 815,
    "no_render_failures": true,
    "no_front_failure": true,
    "require_input_automation": true,
    "no_direct_state_automation": true,
    "min_moving_records": 560,
    "min_horizontal_delta": 1050.0,
    "log_count_assertions": [
      {
        "name": "real_caverns_door_allow",
        "pattern": "^\\[INTERACT_TRACE\\] door allow obj=144\\b",
        "min_count": 1
      },
      {
        "name": "caverns_door_open_transition",
        "pattern": "^\\[DOOR_TRACE\\] frame=\\d+ obj=144 state obj=144 0->1\\b",
        "min_count": 1
      },
      {
        "name": "caverns_door_open_displacement",
        "pattern": "^\\[DOOR_TRACE\\] frame=\\d+ obj=144 displace state=1\\b",
        "min_count": 180
      }
    ],
    "setup_target_milestones": [
      {
        "name": "ramp_door_near_setup_pad_108",
        "frame_at_or_after": 140,
        "target": {"kind": "object", "type_name": "door", "obj": 144, "pad": 108},
        "max_horizontal_distance": 75.0,
        "max_abs_y_delta": 120.0
      },
      {
        "name": "next_room_near_setup_pad_191",
        "frame_at_or_after": 680,
        "target": {"kind": "pad", "pad": 191},
        "max_horizontal_distance": 220.0,
        "max_abs_y_delta": 130.0
      }
    ],
    "position_milestones": [
      {
        "name": "ramp_door_contact",
        "frame_at_or_after": 140,
        "min_horizontal_delta": 112.0,
        "min_abs_z_delta": 110.0
      },
      {
        "name": "post_door_backoff",
        "frame_at_or_after": 220,
        "min_horizontal_delta": 58.0
      },
      {
        "name": "next_room_transition",
        "frame_at_or_after": 500,
        "min_horizontal_delta": 1000.0,
        "min_abs_z_delta": 1000.0
      },
      {
        "name": "next_room_cluster_reach",
        "frame_at_or_after": 680,
        "min_horizontal_delta": 1050.0,
        "min_abs_z_delta": 1050.0
      },
      {
        "name": "post_input_next_room_rest",
        "frame_at_or_after": 819,
        "min_horizontal_delta": 1050.0,
        "min_abs_z_delta": 1050.0
      }
    ],
    "state_milestones": [
      {
        "name": "late_caverns_stable",
        "frame_at_or_after": 800,
        "checks": [
          {"path": "front.active_stage", "op": "==", "value": 39},
          {"path": "front.bond_kia", "op": "==", "value": 0},
          {"path": "front.mission_failed", "op": "==", "value": 0}
        ]
      }
    ]
  }
}
