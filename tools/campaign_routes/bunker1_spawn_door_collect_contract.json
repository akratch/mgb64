{
  "schema": "mgb64.campaign_route.v1",
  "name": "bunker1_spawn_door_collect_contract",
  "level": 9,
  "frames": 520,
  "route_class": "input_interaction",
  "description": "Bunker 1 stock-spawn controller route that opens the first corridor door and reaches the next-room pickup cluster. This proves real input-driven door interaction and collect behavior without warp, force, item injection, or stage-state automation.",
  "env": {
    "GE007_TRACE_FLOW_ONLY": 1,
    "GE007_DOOR_TRACE": 1,
    "GE007_DOOR_TRACE_OBJ": 140,
    "GE007_DOOR_TRACE_BUDGET": 800,
    "GE007_DOOR_TRACE_FRAME_MAX": 520,
    "GE007_INTERACT_TRACE": 1,
    "GE007_INTERACT_TRACE_BUDGET": 240
  },
  "input_segments": [
    {"name": "corridor_door_approach", "start": 80, "duration": 220, "inputs": ["forward", "right"]},
    {"name": "door_open_press", "start": 160, "duration": 8, "inputs": ["b"]},
    {"name": "post_door_collect_probe", "start": 220, "duration": 8, "inputs": ["b"]},
    {"name": "late_collect_probe", "start": 280, "duration": 8, "inputs": ["b"]},
    {"name": "stability_collect_probe", "start": 340, "duration": 8, "inputs": ["b"]}
  ],
  "assertions": {
    "expect_frame_exit": true,
    "min_records": 515,
    "no_render_failures": true,
    "no_front_failure": true,
    "require_input_automation": true,
    "no_direct_state_automation": true,
    "min_moving_records": 210,
    "min_horizontal_delta": 780.0,
    "log_count_assertions": [
      {
        "name": "real_corridor_door_allow",
        "pattern": "^\\[INTERACT_TRACE\\] door allow obj=140\\b",
        "min_count": 1
      },
      {
        "name": "corridor_door_open_transition",
        "pattern": "^\\[DOOR_TRACE\\] frame=\\d+ obj=140 state obj=140 0->1\\b",
        "min_count": 1
      },
      {
        "name": "corridor_door_open_displacement",
        "pattern": "^\\[DOOR_TRACE\\] frame=\\d+ obj=140 displace state=1\\b",
        "min_count": 45
      },
      {
        "name": "next_room_collect_begin",
        "pattern": "^\\[INTERACT_TRACE\\] collect begin .*\\bobjtype=20\\b",
        "min_count": 1
      },
      {
        "name": "next_room_collect_free",
        "pattern": "^\\[INTERACT_TRACE\\] collect free objtype=20 collectType=1\\b",
        "min_count": 1
      }
    ],
    "setup_target_milestones": [
      {
        "name": "first_corridor_door_near_setup_pad_16",
        "frame_at_or_after": 140,
        "target": {"kind": "object", "type_name": "door", "obj": 140, "pad": 16},
        "max_horizontal_distance": 60.0,
        "max_abs_y_delta": 70.0
      },
      {
        "name": "next_room_near_prop_pad_10052",
        "frame_at_or_after": 300,
        "target": {"kind": "object", "type_name": "prop", "obj": 32, "pad": 10052},
        "max_horizontal_distance": 110.0,
        "max_abs_y_delta": 180.0
      }
    ],
    "position_milestones": [
      {
        "name": "corridor_door_contact",
        "frame_at_or_after": 140,
        "min_horizontal_delta": 220.0,
        "min_abs_z_delta": 220.0
      },
      {
        "name": "post_door_push",
        "frame_at_or_after": 260,
        "min_horizontal_delta": 650.0,
        "min_abs_x_delta": 180.0,
        "min_abs_z_delta": 620.0
      },
      {
        "name": "next_room_pickup_cluster",
        "frame_at_or_after": 300,
        "min_horizontal_delta": 780.0,
        "min_abs_x_delta": 180.0,
        "min_abs_z_delta": 740.0
      },
      {
        "name": "post_collect_stable",
        "frame_at_or_after": 519,
        "min_horizontal_delta": 780.0,
        "min_abs_x_delta": 180.0,
        "min_abs_z_delta": 740.0
      }
    ],
    "state_milestones": [
      {
        "name": "post_collect_survival",
        "frame_at_or_after": 500,
        "checks": [
          {"path": "front.active_stage", "op": "==", "value": 9},
          {"path": "front.bond_kia", "op": "==", "value": 0},
          {"path": "front.mission_failed", "op": "==", "value": 0}
        ]
      }
    ]
  }
}
