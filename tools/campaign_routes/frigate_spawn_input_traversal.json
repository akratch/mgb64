        "min_abs_z_delta": 350.0
      },
      {
        "name": "lifeboat_side_push",
        "frame_at_or_after": 220,
        "min_horizontal_delta": 550.0,
        "min_abs_x_delta": 180.0,
        "min_abs_z_delta": 520.0
      },
      {
        "name": "post_input_coast",
        "frame_at_or_after": 299,
        "min_horizontal_delta": 550.0,
        "min_abs_x_delta": 180.0,
        "min_abs_z_delta": 520.0
      }
    ]
